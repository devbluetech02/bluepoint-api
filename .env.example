# =====================================================
# BluePoint API - Variáveis de Ambiente
# Copie este arquivo para .env e configure os valores
# =====================================================

# =====================================================
# Portas dos Serviços
# =====================================================
API_PORT=3003
POSTGRES_PORT=5440
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# =====================================================
# Banco de Dados PostgreSQL
# =====================================================
DB_USERNAME=bluepoint
DB_PASSWORD=bluepoint123
DB_DATABASE=bluepoint
DB_SSLMODE=disable

# Banco vetorizado (PostgreSQL + pgvector) - usado por scripts/clone-db-to-vector.sh
# VECTOR_DB_HOST=localhost
# VECTOR_DB_PORT=5432
# VECTOR_DB_NAME=bluepoint_vector
# VECTOR_DB_USER=bluepoint
# VECTOR_DB_PASSWORD=Bluetech*9090

# Embeddings (popular coluna embedding - script populate-embeddings.mjs)
# OPENAI_API_KEY=sk-...
# OpenRouter: OPENAI_API_BASE_URL=https://openrouter.ai/api/v1
# Modelo (OpenRouter: use ex. openai/text-embedding-3-small): OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =====================================================
# JWT - Autenticação
# =====================================================
# IMPORTANTE: Gere uma chave secreta forte para produção
# Você pode gerar uma com: openssl rand -base64 64
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_mude_para_producao
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =====================================================
# Email/SMTP
# =====================================================
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu_usuario@exemplo.com
SMTP_PASS=sua_senha_smtp
EMAIL_FROM=noreply@exemplo.com

# =====================================================
# URL Base da Aplicação
# =====================================================
BASE_URL=http://localhost:3000

# =====================================================
# MinIO - Object Storage
# =====================================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bluepoint

# =====================================================
# Redis - Cache
# =====================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =====================================================
# Token Fixo - Biometria (Sistemas Externos)
# =====================================================
# Token para sistemas externos acessarem endpoints de biometria
# Gere um token seguro com: openssl rand -hex 24
BIOMETRIA_API_TOKEN=bp_bio_9f8a7b6c5d4e3f2a1b0c9d8e7f6a5b4c

# =====================================================
# Portal do Colaborador - API de Ocorrências
# =====================================================
# Integração com Portal do Colaborador para registro
# automático de ocorrências (atrasos, faltas, etc.)
PORTAL_COLABORADOR_URL=https://portal-do-colaborador.bluetechfilms.com.br
PORTAL_COLABORADOR_API_KEY=8427613e4df99c318bb0a4e00ba0f8c5020d0c6f05eb4764bb8b981914328ce2

# =====================================================
# OneSignal - Push Notifications
# =====================================================
ONESIGNAL_APP_ID=af873024-8e48-412b-8de1-ab43da292716
ONESIGNAL_REST_API_KEY=

# Icone personalizado para push notifications
# PUSH_ICON_URL = URL publica da logo (256x256 PNG recomendado)
# PUSH_SMALL_ICON = nome do drawable no app Android (ex: ic_notification)
PUSH_ICON_URL=
PUSH_SMALL_ICON=

# =====================================================
# Google Gemini - IA para Alertas Inteligentes (Gratuito)
# =====================================================
# Obtenha sua chave em: https://aistudio.google.com/apikey
# Plano gratuito: 15 req/min, 1M tokens/dia
GEMINI_API_KEY=
